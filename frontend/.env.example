NUXT_PUBLIC_API_BASE=http://localhost:8000/api

# Realtime proposal sync tuning
NUXT_PUBLIC_TENDER_REALTIME_CHUNK_SIZE=120
NUXT_PUBLIC_TENDER_REALTIME_MAX_INCREMENTAL_IDS=480
NUXT_PUBLIC_TENDER_REALTIME_DELTA_IDS_THRESHOLD=120

# Organizer sync profile by proposal volume
NUXT_PUBLIC_TENDER_REALTIME_PROPOSAL_THRESHOLD_MEDIUM=300
NUXT_PUBLIC_TENDER_REALTIME_PROPOSAL_THRESHOLD_LARGE=1000
NUXT_PUBLIC_TENDER_REALTIME_PROPOSAL_THRESHOLD_XLARGE=3000
NUXT_PUBLIC_TENDER_REALTIME_SYNC_MS_SMALL=30000
NUXT_PUBLIC_TENDER_REALTIME_SYNC_MS_MEDIUM=60000
NUXT_PUBLIC_TENDER_REALTIME_SYNC_MS_LARGE=120000
NUXT_PUBLIC_TENDER_REALTIME_SYNC_MS_XLARGE=180000

# Idle backoff profile
NUXT_PUBLIC_TENDER_REALTIME_IDLE_L1_THRESHOLD=4
NUXT_PUBLIC_TENDER_REALTIME_IDLE_L2_THRESHOLD=8
NUXT_PUBLIC_TENDER_REALTIME_IDLE_L3_THRESHOLD=12
NUXT_PUBLIC_TENDER_REALTIME_IDLE_L1_MIN_SYNC_MS=90000
NUXT_PUBLIC_TENDER_REALTIME_IDLE_L2_MIN_SYNC_MS=120000
NUXT_PUBLIC_TENDER_REALTIME_IDLE_L3_MIN_SYNC_MS=180000

# Burst + hidden/offline behavior
NUXT_PUBLIC_TENDER_REALTIME_BURST_PENDING_SMALL=200
NUXT_PUBLIC_TENDER_REALTIME_BURST_PENDING_MEDIUM=160
NUXT_PUBLIC_TENDER_REALTIME_BURST_PENDING_LARGE=120
NUXT_PUBLIC_TENDER_REALTIME_BURST_PENDING_XLARGE=80
NUXT_PUBLIC_TENDER_REALTIME_BURST_SYNC_MULTIPLIER=2
NUXT_PUBLIC_TENDER_REALTIME_HIDDEN_MIN_SYNC_MS=60000
NUXT_PUBLIC_TENDER_REALTIME_HIDDEN_SYNC_MULTIPLIER=2
NUXT_PUBLIC_TENDER_REALTIME_OFFLINE_FALLBACK_MS=180000
NUXT_PUBLIC_TENDER_REALTIME_PAUSE_WHEN_HIDDEN=1
NUXT_PUBLIC_TENDER_REALTIME_SYNC_JITTER_RATIO=0.15
