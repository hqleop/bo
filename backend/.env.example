DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database: sqlite or mysql
DB_ENGINE=sqlite
DB_NAME=bidopen
DB_USER=admin
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# DRF throttling
DRF_THROTTLE_USER=300/min
DRF_THROTTLE_ANON=60/min

# Channels / realtime
USE_REDIS_CHANNEL_LAYER=0
REDIS_URL=redis://127.0.0.1:6379/0
WS_ALLOW_QUERY_TOKEN=0

# Short-lived cache for proposal status sync (seconds)
STATUS_SYNC_CACHE_TTL_SECONDS=2
STATUS_SYNC_THROTTLE_PER_MINUTE=120
STATUS_SYNC_LOG_METRICS=0

# Realtime websocket burst coalescing
REALTIME_PROPOSAL_EVENT_COALESCE_MS=250
REALTIME_PROPOSAL_EVENT_COALESCE_MAX_IDS=300
